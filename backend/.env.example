# CloudDoctor Backend Environment
MONGO_URL=mongodb://localhost:27017
DB_NAME=clouddoctor
CORS_ORIGINS=*

# Emergent LLM Key (or your OpenAI API key)
EMERGENT_LLM_KEY=your_emergent_llm_key_here

# BetterStack Logtail
BETTERSTACK_SOURCE_TOKEN=your_source_token_here
BETTERSTACK_QUERY_TOKEN=your_query_token_here
